{
  "info": {
    "name": "SocialAPI — Grid07 Assignment",
    "description": "Run requests in order: Setup → Phase 1 → Phase 2 guardrail tests.\nBase URL: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "postId",  "value": "1",                    "type": "string" }
  ],
  "item": [
    {
      "name": "0 — Setup (seed data first)",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"isPremium\": true\n}"
            }
          }
        },
        {
          "name": "Create Bot",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/bots", "host": ["{{baseUrl}}"], "path": ["api", "bots"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"BotAlpha\",\n  \"personaDescription\": \"A helpful discussion bot.\"\n}"
            }
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "List Bots",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/bots", "host": ["{{baseUrl}}"], "path": ["api", "bots"] }
          }
        }
      ]
    },
    {
      "name": "Phase 1 — Core API",
      "item": [
        {
          "name": "Create Post (User author)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api", "posts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"content\": \"Hello world! This is my first post.\"\n}"
            }
          }
        },
        {
          "name": "Create Post (Bot author)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api", "posts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"I am a bot posting some content.\"\n}"
            }
          }
        },
        {
          "name": "Add Comment (Human — +50 virality, no guardrails)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/comments",
              "host": ["{{baseUrl}}"], "path": ["api", "posts", "{{postId}}", "comments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"content\": \"Great post!\",\n  \"depthLevel\": 1\n}"
            }
          }
        },
        {
          "name": "Add Comment (Bot — +1 virality, guardrails active)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/comments",
              "host": ["{{baseUrl}}"], "path": ["api", "posts", "{{postId}}", "comments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Interesting take on this!\",\n  \"depthLevel\": 1\n}"
            }
          }
        },
        {
          "name": "Like a Post (+20 virality)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/like",
              "host": ["{{baseUrl}}"], "path": ["api", "posts", "{{postId}}", "like"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Phase 2 — Guardrail Tests",
      "item": [
        {
          "name": "[400] Vertical Cap — depth > 20",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/comments",
              "host": ["{{baseUrl}}"], "path": ["api", "posts", "{{postId}}", "comments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Deeply nested reply — should be rejected.\",\n  \"depthLevel\": 21\n}"
            }
          }
        },
        {
          "name": "[429] Cooldown Cap — same bot+user within 10 min",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/comments",
              "host": ["{{baseUrl}}"], "path": ["api", "posts", "{{postId}}", "comments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Second reply within 10 minutes — should be rejected.\",\n  \"depthLevel\": 1\n}"
            }
          }
        },
        {
          "name": "[429] Horizontal Cap — 101st bot reply",
          "description": "First run: redis-cli SET post:1:bot_count 100\nThen send this — should get 429.",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/comments",
              "host": ["{{baseUrl}}"], "path": ["api", "posts", "{{postId}}", "comments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Post is at 100 bot replies — should be rejected.\",\n  \"depthLevel\": 1\n}"
            }
          }
        }
      ]
    }
  ]
}
